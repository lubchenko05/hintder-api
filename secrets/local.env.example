# Copy to secrets/local.env and adjust. Loaded by main.py at startup.

ENV=dev

# Database — match the local Postgres role/db you created by hand.
POSTGRES_USER=dating
POSTGRES_PASSWORD=dating
POSTGRES_DB=dating
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT signing key (any long random string for dev).
JWT_SECRET_KEY=change_me_in_dev

# Firebase Admin — path to the service-account JSON for the hintder project.
# Leave blank to use Application Default Credentials.
FIREBASE_CREDENTIALS_FILE=secrets/firebase-service-account.json
FIREBASE_PROJECT_ID=

# AI — real Gemini (latest Flash, not Pro). Vertex AI by default, reusing the
# Seeto GCP project + service account (secrets/gemini-vertex-sa.json).
AI_MODEL=gemini-3.5-flash
AI_USE_VERTEX=true
AI_VERTEX_PROJECT=seeto-315cd
AI_VERTEX_LOCATION=global
AI_VERTEX_CREDENTIALS_FILE=secrets/gemini-vertex-sa.json
# To use a Google AI Studio key instead: AI_USE_VERTEX=false + AI_API_KEY=...
AI_API_KEY=

# Cloud Storage — screenshots bucket + dedicated service-account key.
STORAGE_BUCKET=dating-client-storage-30d
STORAGE_CREDENTIALS_FILE=secrets/storage-sa.json

# Paddle — mocked until real IDs exist. Leave blank to keep the mock path.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox
